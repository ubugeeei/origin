use std::command::status

fn main() -> unknown!() {
  if status "xcode-select -p >/dev/null 2>&1" != 0 {
    shell "printf '%s\n' 'Install Command Line Tools first with: xcode-select --install' >&2; exit 1"?
  }
  else {
    ()
  }

  if ".git".is_dir() == false {
    shell "git init"?
  }
  else {
    ()
  }

  shell "git add ."?
  shell "git status --short"?
}

main()?
