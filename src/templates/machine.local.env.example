# Machine-specific overrides for this repository.
# Copy this file to machine/local.env and edit the values you want to pin.
# Keep this file data-only: use plain single-quoted ORIGIN_* assignments only.

ORIGIN_SYSTEM='aarch64-darwin'
ORIGIN_USERNAME='your-username'
ORIGIN_HOME='/Users/your-username'
ORIGIN_WORKSPACE_ROOT='/Users/your-username/Source'

ORIGIN_COMPUTER_NAME='Your Mac'
ORIGIN_HOSTNAME='your-mac'
ORIGIN_LOCAL_HOSTNAME='your-mac'

ORIGIN_GIT_USER_NAME='Your Name'
ORIGIN_GIT_USER_EMAIL='you@example.com'
ORIGIN_GITHUB_USER='your-github-user'
# Set a signing key to enable signed commits. For SSH signing, also set
# ORIGIN_GIT_GPG_FORMAT='ssh' and use the public key path.
# ORIGIN_GIT_SIGNING_KEY='~/.ssh/id_ed25519.pub'
# ORIGIN_GIT_GPG_FORMAT='ssh'

# Optional machine-level toggles.
ORIGIN_TOUCH_ID_SUDO_AUTH='false'

# Optional bundle identifier namespace for generated Chrome app wrappers.
# ORIGIN_APP_NAMESPACE='dev.origin'
